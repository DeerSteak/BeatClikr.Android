<?xml version="1.0" encoding="utf-8"?>
<!-- API 31+ backup and device-transfer rules -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="beatclikr.db"/>
        <include domain="database" path="beatclikr.db-wal"/>
        <include domain="database" path="beatclikr.db-shm"/>
        <include domain="sharedpref" path="beatclikr_preferences.xml"/>
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="beatclikr.db"/>
        <include domain="database" path="beatclikr.db-wal"/>
        <include domain="database" path="beatclikr.db-shm"/>
        <include domain="sharedpref" path="beatclikr_preferences.xml"/>
    </device-transfer>
</data-extraction-rules>
